[
  {
    "name": "human root help",
    "argv": ["--help"],
    "expected": {
      "status": 0,
      "stdout": "text",
      "stderr": "empty",
      "streams": { "stdout": "prose", "stderr": "empty" }
    }
  },
  {
    "name": "json root help",
    "argv": ["--json", "--help"],
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  },
  {
    "name": "agent root help",
    "argv": ["--agent", "--help"],
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  },
  {
    "name": "agent flag capabilities",
    "argv": ["--agent", "capabilities"],
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  },
  {
    "name": "agent env capabilities",
    "argv": ["capabilities"],
    "env": {
      "PRIVACY_POOLS_AGENT": "1"
    },
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  },
  {
    "name": "json wins over csv on discovery",
    "argv": ["--json", "--output", "csv", "capabilities"],
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  },
  {
    "name": "quiet status keeps concise stdout",
    "argv": ["--quiet", "--no-banner", "status", "--no-check"],
    "seededHome": true,
    "expected": {
      "status": 0,
      "stdout": "text",
      "stderr": "empty",
      "streams": { "stdout": "prose", "stderr": "empty" }
    }
  },
  {
    "name": "human capabilities uses stderr",
    "argv": ["--no-banner", "capabilities"],
    "expected": {
      "status": 0,
      "stdout": "empty",
      "stderr": "text",
      "streams": { "stdout": "empty", "stderr": "prose" }
    }
  },
  {
    "name": "quiet pools activity suppresses human streams",
    "argv": ["--quiet", "pools", "activity"],
    "env": {
      "PRIVACY_POOLS_ASP_HOST": "<fixture>",
      "PRIVACY_POOLS_RPC_URL_SEPOLIA": "<fixture>"
    },
    "expected": {
      "status": 0,
      "stdout": "empty",
      "stderr": "empty",
      "streams": { "stdout": "empty", "stderr": "empty" }
    }
  },
  {
    "name": "agent status suppresses stderr and keeps envelope stdout",
    "argv": ["--agent", "status", "--no-check"],
    "seededHome": true,
    "expected": {
      "status": 0,
      "stdout": "json",
      "stderr": "empty",
      "streams": { "stdout": "envelope", "stderr": "empty" }
    }
  }
]
