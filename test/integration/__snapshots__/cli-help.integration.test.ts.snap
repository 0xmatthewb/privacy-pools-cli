// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`CLI --help snapshots root --help snapshot 1`] = `
"Usage: privacy-pools [options] [command]
Privacy Pools: a compliant way to transact privately on Ethereum
  Explore (no wallet needed)
  pools                List available pools and assets
  activity             Show public activity feed
  stats                Show public statistics
  status               Show configuration and check connection health
  guide                Show usage guide, workflow, and reference
  capabilities         Describe CLI capabilities for agent discovery
  Transact (run init first)
  init                 Initialize wallet and configuration
  deposit              Deposit into a pool
  withdraw             Withdraw from a pool
  ragequit|exit        Publicly withdraw funds to your deposit address
  accounts             List your Pool Accounts (individual deposit lineages)
                       with balances
  history              Show chronological event history (deposits, withdrawals,
                       exits)
  sync                 Force-sync local account state from onchain events
Options:
  -V, --version        output the version number
  -c, --chain <name>   Target chain (mainnet, arbitrum, optimism, ...)
  -j, --json           Machine-readable JSON output
  --format <format>    Output format: table (default), csv, json
  -y, --yes            Skip confirmation prompts
  --agent              Machine-friendly mode (alias for --json --yes --quiet)
  --timeout <seconds>  RPC/API request timeout in seconds (default: 30)
  -h, --help           display help for command
  Get started:      privacy-pools init  (or pp init)
  Full guide:       privacy-pools guide
  Command help:     privacy-pools <command> --help"
`;

exports[`CLI --help snapshots init --help snapshot 1`] = `
"Usage: privacy-pools init [options]
Initialize wallet and configuration
Options:
  --mnemonic <phrase>        Import an existing recovery phrase (unsafe: visible
                             in process list)
  --mnemonic-file <path>     Import recovery phrase from a file (raw phrase or
                             Privacy Pools backup file)
  --show-mnemonic            Include generated mnemonic in JSON output (unsafe:
                             may be logged or piped)
  --private-key <key>        Set the signer private key (unsafe: visible in
                             process list)
  --private-key-file <path>  Set the signer private key from a file
  --default-chain <chain>    Set default chain
  --rpc-url <url>            Set RPC URL for the default chain
  --force                    Overwrite existing configuration without prompting
  -h, --help                 display help for command
Privacy Pools uses two keys:
  Recovery phrase: keeps your deposits private (generated during init)
  Wallet key:     pays gas and sends transactions (can be set later)
  These are independent. Set the wallet key via PRIVACY_POOLS_PRIVATE_KEY env var.
Examples:
  privacy-pools init
  privacy-pools init --yes --default-chain mainnet
  privacy-pools init --force --yes --default-chain mainnet
  privacy-pools init --json --show-mnemonic
  privacy-pools init --mnemonic "word ..." --private-key 0x...
JSON output (--json):
  { defaultChain, signerKeySet, mnemonicRedacted?, mnemonic? (only with --show-mnemonic) }"
`;

exports[`CLI --help snapshots status --help snapshot 1`] = `
"Usage: privacy-pools status [options]
Show configuration and check connection health
Options:
  --check      Run both RPC and ASP health checks
  --no-check   Suppress default health checks
  --check-rpc  Actively test RPC connectivity
  --check-asp  Actively test ASP liveness
  -h, --help   display help for command
Examples:
  privacy-pools status
  privacy-pools status --check
  privacy-pools status --no-check
  privacy-pools status --json --check-rpc
  privacy-pools status --chain mainnet --rpc-url https://...
JSON output (--json):
  { configExists, defaultChain, selectedChain, rpcUrl, mnemonicSet, signerKeySet, signerAddress, aspLive?, rpcLive? }"
`;

exports[`CLI --help snapshots pools --help snapshot 1`] = `
"Usage: privacy-pools pools [options] [asset]
List available pools and assets
Arguments:
  asset             Asset symbol for detail view (e.g. ETH, BOLD)
Options:
  --all-chains      Include testnet chains (mainnets shown by default)
  --search <query>  Filter by chain/symbol/address/scope
  --sort <mode>     Sort mode (default, asset-asc, asset-desc, tvl-desc,
                    tvl-asc, deposits-desc, deposits-asc, chain-asset) (default:
                    "tvl-desc")
  -h, --help        display help for command
Examples:
  privacy-pools pools
  privacy-pools pools ETH
  privacy-pools pools BOLD --chain mainnet
  privacy-pools pools --all-chains --sort tvl-desc
  privacy-pools pools --search usdc --sort asset-asc
  privacy-pools pools --json --chain mainnet
JSON output (--json):
  { chain|allChains, search, sort, pools: [{ chain?, symbol, asset, pool, scope, totalDepositsCount, totalDepositsValue, acceptedDepositsValue, pendingDepositsValue, ... }], warnings? }"
`;

exports[`CLI --help snapshots activity --help snapshot 1`] = `
"Usage: privacy-pools activity [options]
Show public activity feed
Options:
  -a, --asset <symbol|address>  Filter to one pool asset on the selected chain
  --page <n>                    Page number (default: "1")
  --limit <n>                   Items per page (default: "12")
  -h, --help                    display help for command
Examples:
  privacy-pools activity
  privacy-pools activity --page 2 --limit 20
  privacy-pools activity --asset ETH
  privacy-pools activity --asset USDC --json --chain mainnet
JSON output (--json):
  { mode, chain, page, perPage, total?, totalPages?, events: [{ type, txHash, reviewStatus, amountRaw, poolSymbol, poolAddress, chainId, timestamp }] }"
`;

exports[`CLI --help snapshots stats --help snapshot 1`] = `
"Usage: privacy-pools stats [options] [command]
Show public statistics
Options:
  -h, --help      display help for command
Commands:
  global          Show global Privacy Pools statistics (all-time and last 24h)
  pool [options]  Show statistics for a specific pool (all-time and last 24h)
  help [command]  display help for command
Examples:
  privacy-pools stats global
  privacy-pools stats pool --asset ETH
  privacy-pools stats pool --asset USDC --json --chain mainnet"
`;

exports[`CLI --help snapshots deposit --help snapshot 1`] = `
"Usage: privacy-pools deposit [options] <amountOrAsset> [amount]
Deposit into a pool
Arguments:
  amountOrAsset                 Amount to deposit (or asset symbol, see
                                examples)
  amount                        Amount (when asset is the first argument)
Options:
  -a, --asset <symbol|address>  Asset to deposit (symbol like ETH, USDC, or
                                contract address)
  --unsigned                    Build unsigned transaction payload(s); do not
                                submit
  --unsigned-format <format>    Unsigned output format (with --unsigned):
                                envelope|tx
  --dry-run                     Validate and preview the transaction without
                                submitting
  -h, --help                    display help for command
Examples:
  privacy-pools deposit 0.1 ETH
  privacy-pools deposit 0.05 ETH --json --yes
  privacy-pools deposit 0.05 ETH --unsigned
  privacy-pools deposit 0.1 ETH --dry-run
  privacy-pools deposit 0.1 ETH --chain mainnet
  privacy-pools deposit 0.1 --asset ETH
Prerequisites:
  Requires: init
JSON output (--json):
  { txHash, amount, committedValue, asset, chain, poolAccountId, blockNumber, explorerUrl, ... }"
`;

exports[`CLI --help snapshots withdraw --help snapshot 1`] = `
"Usage: privacy-pools withdraw [options] [command] [amountOrAsset] [amount]
Withdraw from a pool
Arguments:
  amountOrAsset                             Amount to withdraw (or asset symbol, see examples)
  amount                                    Amount (when asset is the first argument)
Options:
  -t, --to <address>                        Recipient address (required for relayed)
  -p, --from-pa <PA-#|#>                    Withdraw from a specific Pool Account (e.g. PA-2)
  --direct                                  Use direct withdrawal (not privacy-preserving; use relayed mode for private withdrawals)
  --unsigned                                Build unsigned payload(s); do not submit
  --unsigned-format <format>                Unsigned output format (with --unsigned): envelope|tx
  --dry-run                                 Generate and verify withdrawal artifacts without submitting
  -a, --asset <symbol|address>              Asset to withdraw
  --all                                     Withdraw entire Pool Account balance
  --extra-gas                               Request gas tokens with withdrawal (default: true for ERC20)
  --no-extra-gas                            Disable extra gas request
  -h, --help                                display help for command
Commands:
  quote [options] <amountOrAsset> [amount]  Request relayer quote and limits without generating a proof
Examples:
  privacy-pools withdraw 0.05 ETH --to 0xRecipient...
  privacy-pools withdraw 0.05 ETH --to 0xRecipient... -p PA-2
  privacy-pools withdraw --all ETH --to 0xRecipient...
  privacy-pools withdraw 50% ETH --to 0xRecipient...
  privacy-pools withdraw 0.05 ETH --direct
  privacy-pools withdraw 0.1 ETH --to 0xRecipient... --dry-run
  privacy-pools withdraw quote 0.1 ETH --to 0xRecipient...
  privacy-pools withdraw 0.05 ETH --to 0xRecipient... --chain mainnet
Prerequisites:
  Requires: init (account state should be synced)
JSON output (--json):
  { mode, txHash, amount, recipient, asset, chain, poolAccountId, blockNumber, explorerUrl, ... }"
`;

exports[`CLI --help snapshots ragequit --help snapshot 1`] = `
"Usage: privacy-pools ragequit|exit [options] [asset]
Publicly withdraw funds to your deposit address
Arguments:
  asset                         Optional positional asset alias (e.g., ragequit
                                ETH)
Options:
  -a, --asset <symbol|address>  Asset pool to exit from
  -p, --from-pa <PA-#|#>        Ragequit a specific Pool Account (e.g. PA-2)
  --unsigned                    Build unsigned transaction payload; do not
                                submit
  --unsigned-format <format>    Unsigned output format (with --unsigned):
                                envelope|tx
  --dry-run                     Generate proof and validate without submitting
  -h, --help                    display help for command
  Use 'withdraw' to withdraw privately once your deposit is ASP-approved.
  Use 'ragequit' at any time to recover funds publicly to your deposit
  address, even if not approved. No ASP approval is needed, but your
  deposit address is revealed onchain.
Examples:
  privacy-pools ragequit ETH -p PA-1
  privacy-pools ragequit ETH --unsigned -p PA-1
  privacy-pools ragequit ETH --dry-run -p PA-1
  privacy-pools ragequit ETH -p PA-1 --chain mainnet
  privacy-pools ragequit --asset ETH -p PA-1
Prerequisites:
  Requires: init (account state should be synced)
JSON output (--json):
  { txHash, amount, asset, chain, poolAccountId, blockNumber, explorerUrl, ... }"
`;

exports[`CLI --help snapshots accounts --help snapshot 1`] = `
"Usage: privacy-pools accounts [options]
List your Pool Accounts (individual deposit lineages) with balances
Options:
  --no-sync   Use cached data (faster, but may be stale)
  --all       Include exited and fully spent Pool Accounts
  --details   Show additional details per Pool Account
  -h, --help  display help for command
Examples:
  privacy-pools accounts
  privacy-pools accounts --all
  privacy-pools accounts --details
  privacy-pools accounts --json
  privacy-pools accounts --no-sync --chain mainnet
Prerequisites:
  Requires: init
JSON output (--json):
  { chain, accounts: [{ poolAccountId, status, asset, scope, value, hash, label, ... }] }"
`;

exports[`CLI --help snapshots history --help snapshot 1`] = `
"Usage: privacy-pools history [options]
Show chronological event history (deposits, withdrawals, exits)
Options:
  --no-sync        Use cached data (faster, but may be stale)
  -n, --limit <n>  Show last N events (default: "50")
  -h, --help       display help for command
Examples:
  privacy-pools history
  privacy-pools history --limit 10
  privacy-pools history --json
  privacy-pools history --no-sync --chain mainnet
Prerequisites:
  Requires: init
JSON output (--json):
  { chain, events: [{ type, asset, poolAddress, poolAccountId, value, blockNumber, txHash, explorerUrl }] }"
`;

exports[`CLI --help snapshots sync --help snapshot 1`] = `
"Usage: privacy-pools sync [options]
Force-sync local account state from onchain events
Options:
  -a, --asset <symbol|address>  Sync only a single pool asset
  -h, --help                    display help for command
Examples:
  privacy-pools sync
  privacy-pools sync --asset ETH --json
  privacy-pools sync --chain mainnet
Prerequisites:
  Requires: init
JSON output (--json):
  { chain, syncedPools, syncedSymbols, spendableCommitments, previousSpendableCommitments }"
`;

exports[`CLI --help snapshots guide --help snapshot 1`] = `
"Usage: privacy-pools guide [options]
Show usage guide, workflow, and reference
Options:
  -h, --help  display help for command"
`;

exports[`CLI --help snapshots capabilities --help snapshot 1`] = `
"Usage: privacy-pools capabilities [options]
Describe CLI capabilities for agent discovery
Options:
  -h, --help  display help for command
Examples:
  privacy-pools capabilities
  privacy-pools capabilities --json
JSON output (--json):
  { commands[], globalFlags[], agentWorkflow[], agentNotes{}, schemas{}, supportedChains[], jsonOutputContract }"
`;

exports[`CLI --help snapshots completion --help snapshot 1`] = `
"Usage: privacy-pools completion [options] [shell]
Generate shell completion script
Arguments:
  shell                Target shell (bash|zsh|fish)
Options:
  -s, --shell <shell>  Target shell (choices: "bash", "zsh", "fish")
  -h, --help           display help for command
Examples:
  privacy-pools completion zsh > ~/.zsh/completions/_privacy-pools
  privacy-pools completion bash > ~/.local/share/bash-completion/completions/privacy-pools
  privacy-pools completion fish > ~/.config/fish/completions/privacy-pools.fish"
`;

exports[`CLI --help snapshots withdraw quote --help snapshot 1`] = `
"Usage: privacy-pools withdraw quote [options] <amountOrAsset> [amount]
Request relayer quote and limits without generating a proof
Arguments:
  amountOrAsset                 Amount to withdraw (or asset symbol, see
                                examples)
  amount                        Amount (when asset is the first argument)
Options:
  -a, --asset <symbol|address>  Asset to quote
  -t, --to <address>            Recipient address (recommended for signed fee
                                commitment)
  -h, --help                    display help for command
Examples:
  privacy-pools withdraw quote 0.1 ETH --to 0xRecipient...
  privacy-pools withdraw quote 100 USDC --json --chain mainnet
Prerequisites:
  Requires: init
JSON output (--json):
  { mode, chain, asset, amount, quoteFeeBPS, quoteExpiresAt, ... }"
`;

exports[`CLI --help snapshots stats global --help snapshot 1`] = `
"Usage: privacy-pools stats global [options]
Show global Privacy Pools statistics (all-time and last 24h)
Options:
  -h, --help  display help for command
Examples:
  privacy-pools stats global
  privacy-pools stats global --json --chain mainnet
JSON output (--json):
  { mode, chain, cacheTimestamp?, allTime?, last24h? }"
`;

exports[`CLI --help snapshots stats pool --help snapshot 1`] = `
"Usage: privacy-pools stats pool [options]
Show statistics for a specific pool (all-time and last 24h)
Options:
  -a, --asset <symbol|address>  Pool asset (symbol like ETH, USDC, or token
                                address)
  -h, --help                    display help for command
Examples:
  privacy-pools stats pool --asset ETH
  privacy-pools stats pool --asset USDC --json --chain mainnet
JSON output (--json):
  { mode, chain, asset, pool, scope, cacheTimestamp?, allTime?, last24h? }"
`;
