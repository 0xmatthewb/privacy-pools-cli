{
  "name": "privacy-pools-cli-json-contract",
  "version": "1.3.0",
  "schemaVersion": "1.3.0",
  "description": "Stable machine-readable output contract for privacy-pools CLI.",
  "envelope": {
    "successBase": {
      "schemaVersion": "semver-string",
      "success": true
    },
    "errorBase": {
      "schemaVersion": "semver-string",
      "success": false,
      "errorCode": "string",
      "errorMessage": "string",
      "error": {
        "code": "string",
        "category": "INPUT|RPC|ASP|RELAYER|PROOF|CONTRACT|UNKNOWN",
        "message": "string",
        "hint": "string?",
        "retryable": "boolean?"
      }
    }
  },
  "exitCodes": {
    "0": "SUCCESS",
    "1": "UNKNOWN_ERROR",
    "2": "INPUT_ERROR",
    "3": "RPC_ERROR",
    "4": "ASP_ERROR",
    "5": "RELAYER_ERROR",
    "6": "PROOF_ERROR",
    "7": "CONTRACT_ERROR"
  },
  "shared": {
    "rawUnsignedTransaction": {
      "to": "0x-prefixed-address",
      "data": "0x-prefixed-hex-calldata",
      "value": "decimal-string-wei",
      "valueHex": "0x-prefixed-hex-quantity-wei",
      "chainId": "number",
      "description": "string"
    },
    "unsignedTransaction": {
      "chainId": "number",
      "from": "0x-prefixed-address|null",
      "to": "0x-prefixed-address",
      "value": "decimal-string-wei",
      "data": "0x-prefixed-hex-calldata",
      "description": "string"
    }
  },
  "commands": {
    "init": {
      "successFields": {
        "defaultChain": "string",
        "signerKeySet": "boolean",
        "mnemonicRedacted": "boolean? (true when a new mnemonic was generated but not printed)",
        "mnemonic": "string? (present only when newly generated and --show-mnemonic is provided)",
        "warning": "string? (security guidance for agents)",
        "nextSteps": "object? ({ requiresMnemonicCapture: boolean, requiresSignerKey: boolean, suggestedCommands: string[] })"
      }
    },
    "status": {
      "successFields": {
        "configExists": "boolean",
        "configDir": "string|null",
        "defaultChain": "string|null",
        "selectedChain": "string|null",
        "rpcUrl": "string|null",
        "rpcIsCustom": "boolean",
        "mnemonicSet": "boolean",
        "signerKeySet": "boolean",
        "signerKeyValid": "boolean",
        "signerAddress": "0x-prefixed-address|null",
        "entrypoint": "0x-prefixed-address|null",
        "aspHost": "string|null",
        "accountFiles": "[{ chain: string, chainId: number }]",
        "aspLive": "boolean|undefined (present when health checks run)",
        "rpcLive": "boolean|undefined (present when health checks run)",
        "rpcBlockNumber": "string|undefined (present when rpc check succeeds)",
        "readyForDeposit": "boolean (configExists && mnemonicSet && signerKeyValid)",
        "readyForWithdraw": "boolean (configExists && mnemonicSet && signerKeyValid)",
        "readyForUnsigned": "boolean (configExists && mnemonicSet)",
        "handoffChecklist": "[{ key: string, met: boolean, remedy: string }]"
      }
    },
    "pools": {
      "successFields": {
        "chain": "string (single-chain mode)",
        "allChains": "boolean? (true when no --chain specified)",
        "search": "string|null",
        "sort": "string",
        "chains": "ChainSummary[]? (multi-chain mode: { chain, pools, error })",
        "pools": "Pool[]",
        "warnings": "PoolWarning[]? (multi-chain mode)"
      },
      "poolFields": {
        "symbol": "string",
        "asset": "0x-prefixed-address",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string",
        "decimals": "number",
        "minimumDeposit": "decimal-string-wei",
        "vettingFeeBPS": "decimal-string",
        "maxRelayFeeBPS": "decimal-string",
        "totalInPoolValue": "decimal-string-wei|null",
        "totalInPoolValueUsd": "string|null",
        "totalDepositsValue": "decimal-string-wei|null",
        "totalDepositsValueUsd": "string|null",
        "acceptedDepositsValue": "decimal-string-wei|null",
        "acceptedDepositsValueUsd": "string|null",
        "pendingDepositsValue": "decimal-string-wei|null",
        "pendingDepositsValueUsd": "string|null",
        "totalDepositsCount": "number|null",
        "acceptedDepositsCount": "number|null",
        "pendingDepositsCount": "number|null",
        "growth24h": "number|null",
        "pendingGrowth24h": "number|null",
        "chain": "string? (present in multi-chain mode)"
      }
    },
    "deposit": {
      "successFields": {
        "operation": "\"deposit\"",
        "txHash": "0x-prefixed-hash",
        "amount": "decimal-string-wei",
        "committedValue": "decimal-string-wei|null",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "label": "decimal-string|null",
        "blockNumber": "decimal-string",
        "explorerUrl": "string|null",
        "nextStep": "string (agent guidance)"
      },
      "variants": {
        "dryRun": {
          "dryRun": true,
          "operation": "\"deposit\"",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "precommitment": "decimal-string",
          "balanceSufficient": "boolean|\"unknown\""
        },
        "unsigned": {
          "mode": "unsigned",
          "operation": "deposit",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "precommitment": "decimal-string",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedTx": {
          "--unsigned-format tx": "RawUnsignedTransaction[]"
        }
      }
    },
    "withdraw": {
      "successFields": {
        "operation": "\"withdraw\"",
        "mode": "\"direct\"|\"relayed\"",
        "txHash": "0x-prefixed-hash",
        "blockNumber": "decimal-string",
        "amount": "decimal-string-wei",
        "recipient": "0x-prefixed-address",
        "explorerUrl": "string|null",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "remainingBalance": "decimal-string-wei",
        "feeBPS": "string? (relayed mode only)",
        "extraGas": "boolean? (relayed mode, ERC20 only)",
        "fee": "null? (direct mode only)",
        "nextStep": "string (agent guidance)"
      },
      "variants": {
        "dryRun": {
          "mode": "\"direct\"|\"relayed\"",
          "dryRun": true,
          "amount": "decimal-string-wei",
          "asset": "string",
          "chain": "string",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "proofPublicSignals": "number",
          "feeBPS": "string? (relayed only)",
          "quoteExpiresAt": "iso8601-string? (relayed only)",
          "extraGas": "boolean? (relayed mode, ERC20 only)"
        },
        "unsignedDirect": {
          "mode": "unsigned",
          "operation": "withdraw",
          "withdrawMode": "direct",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedRelayed": {
          "mode": "unsigned",
          "operation": "withdraw",
          "withdrawMode": "relayed",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "feeBPS": "string",
          "quoteExpiresAt": "iso8601-string",
          "transactions": "UnsignedTransaction[]",
          "relayerRequest": "object"
        },
        "unsignedTx": {
          "--unsigned-format tx": "RawUnsignedTransaction[]"
        }
      },
      "subcommands": {
        "quote": {
          "mode": "relayed-quote",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address|null",
          "minWithdrawAmount": "decimal-string-wei",
          "minWithdrawAmountFormatted": "string (human-readable e.g. 0.01 ETH)",
          "quoteFeeBPS": "string",
          "feeAmount": "decimal-string-wei",
          "netAmount": "decimal-string-wei",
          "feeCommitmentPresent": "boolean",
          "quoteExpiresAt": "iso8601-string|null",
          "extraGas": "boolean? (ERC20 only, present when extra gas requested)"
        }
      }
    },
    "ragequit": {
      "aliases": [
        "exit"
      ],
      "successFields": {
        "operation": "\"ragequit\"",
        "txHash": "0x-prefixed-hash",
        "amount": "decimal-string-wei",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "blockNumber": "decimal-string",
        "explorerUrl": "string|null",
        "nextStep": "string (agent guidance)"
      },
      "variants": {
        "dryRun": {
          "dryRun": true,
          "operation": "\"ragequit\"",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "proofPublicSignals": "number"
        },
        "unsigned": {
          "mode": "unsigned",
          "operation": "ragequit",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedTx": {
          "--unsigned-format tx": "RawUnsignedTransaction[]"
        }
      }
    },
    "accounts": {
      "successFields": {
        "chain": "string",
        "accounts": "Account[]",
        "balances": "Balance[]",
        "pendingCount": "number"
      },
      "accountFields": {
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "status": "\"spendable\"|\"spent\"|\"exited\"",
        "aspStatus": "\"pending\"|\"approved\"|\"unknown\"",
        "asset": "string",
        "scope": "decimal-string",
        "value": "decimal-string-wei",
        "hash": "decimal-string",
        "label": "decimal-string",
        "blockNumber": "decimal-string",
        "txHash": "0x-prefixed-hash"
      },
      "balanceFields": {
        "asset": "string",
        "balance": "decimal-string-wei (total spendable)",
        "usdValue": "string|null (formatted USD e.g. $1,000.00)",
        "poolAccounts": "number (spendable account count)"
      }
    },
    "history": {
      "successFields": {
        "chain": "string",
        "events": "HistoryEvent[]"
      },
      "eventFields": {
        "type": "\"deposit\"|\"withdrawal\"|\"ragequit\"",
        "asset": "string",
        "poolAddress": "0x-prefixed-address",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "value": "decimal-string-wei",
        "blockNumber": "decimal-string",
        "txHash": "0x-prefixed-hash",
        "explorerUrl": "string|null"
      }
    },
    "activity": {
      "successFields": {
        "mode": "\"pool-activity\"|\"global-activity\"",
        "chain": "string",
        "chains": "string[]? (global-activity with multiple chains)",
        "page": "number",
        "perPage": "number",
        "total": "number|null",
        "totalPages": "number|null",
        "events": "ActivityEvent[]",
        "chainFiltered": "boolean? (true when events were filtered client-side by chain)",
        "note": "string? (present when chainFiltered is true)"
      },
      "poolActivityExtraFields": {
        "asset": "string",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string"
      },
      "eventFields": {
        "type": "string",
        "txHash": "0x-prefixed-hash|null",
        "reviewStatus": "string|null",
        "amountRaw": "decimal-string-wei|null",
        "poolSymbol": "string|null",
        "poolAddress": "0x-prefixed-address|null",
        "chainId": "number|null",
        "timestamp": "number|null (milliseconds)"
      }
    },
    "stats": {
      "globalStats": {
        "mode": "\"global-stats\"",
        "chain": "string",
        "chains": "string[]? (multi-chain mode)",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null",
        "perChain": "ChainStatsEntry[]? (multi-chain mode)"
      },
      "poolStats": {
        "mode": "\"pool-stats\"",
        "chain": "string",
        "asset": "string",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null"
      },
      "timeBasedStatisticsFields": {
        "tvlUsd": "string|null",
        "avgDepositSizeUsd": "string|null",
        "totalDepositsCount": "number|null",
        "totalWithdrawalsCount": "number|null"
      },
      "chainStatsEntryFields": {
        "chain": "string",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null"
      }
    },
    "capabilities": {
      "successFields": {
        "commands": "Command[]",
        "globalFlags": "Flag[]",
        "agentWorkflow": "string[]",
        "jsonOutputContract": "string (semver)",
        "agentNotes": "object (Record<string, string>)",
        "schemas": "object",
        "supportedChains": "Chain[]",
        "safeReadOnlyCommands": "string[]? (commands safe to run without side effects)"
      }
    },
    "sync": {
      "successFields": {
        "chain": "string",
        "syncedPools": "number",
        "syncedSymbols": "string[]? (present on successful sync)",
        "spendableCommitments": "number",
        "previousSpendableCommitments": "number? (count before sync)"
      }
    },
    "guide": {
      "note": "Outputs formatted help text to stderr in interactive mode. In JSON mode, returns the guide as a string.",
      "successFields": {
        "mode": "\"help\"",
        "help": "string (formatted guide text)"
      }
    },
    "meta": {
      "helpEnvelope": {
        "mode": "help",
        "help": "string"
      },
      "versionEnvelope": {
        "mode": "version",
        "version": "semver-string"
      }
    }
  },
  "unsignedCalldataABIs": {
    "depositNative": "function deposit(uint256 _precommitment) payable",
    "depositErc20": "function deposit(address _asset, uint256 _value, uint256 _precommitment)",
    "approveErc20": "function approve(address spender, uint256 amount)",
    "withdrawDirect": "function withdraw((address processooor, bytes data) _withdrawal, (uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[8] pubSignals) _proof)",
    "withdrawRelayed": "function relay((address processooor, bytes data) _withdrawal, (uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[8] pubSignals) _proof, uint256 _scope)",
    "ragequit": "function ragequit((uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[4] pubSignals) _proof)"
  }
}
