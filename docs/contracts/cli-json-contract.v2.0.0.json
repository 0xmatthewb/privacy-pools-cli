{
  "name": "privacy-pools-cli-json-contract",
  "version": "2.0.0",
  "schemaVersion": "2.0.0",
  "description": "Stable machine-readable output contract for privacy-pools CLI.",
  "envelope": {
    "successBase": {
      "schemaVersion": "semver-string",
      "success": true
    },
    "errorBase": {
      "schemaVersion": "semver-string",
      "success": false,
      "errorCode": "string",
      "errorMessage": "string",
      "availableFields": "string[]? (present on INPUT_UNKNOWN_JSON_FIELD)",
      "unknownFields": "string[]? (present on INPUT_UNKNOWN_JSON_FIELD)",
      "error": {
        "code": "string",
        "category": "INPUT|RPC|ASP|RELAYER|PROOF|CONTRACT|UNKNOWN",
        "message": "string",
        "hint": "string?",
        "retryable": "boolean?",
        "availableFields": "string[]? (present on INPUT_UNKNOWN_JSON_FIELD)",
        "unknownFields": "string[]? (present on INPUT_UNKNOWN_JSON_FIELD)"
      }
    }
  },
  "exitCodes": {
    "0": "SUCCESS",
    "1": "UNKNOWN_ERROR",
    "2": "INPUT_ERROR",
    "3": "RPC_ERROR",
    "4": "ASP_ERROR",
    "5": "RELAYER_ERROR",
    "6": "PROOF_ERROR",
    "7": "CONTRACT_ERROR"
  },
  "shared": {
    "nextAction": {
      "command": "string (CLI command name)",
      "reason": "string (why the follow-up is relevant)",
      "when": "string (machine-readable timing label)",
      "cliCommand": "string (fully executable CLI invocation with kebab-case flags)",
      "args": "string[]? (positional arguments to pass)",
      "options": "Record<string, string|number|boolean|null>? (named options in source-object form; prefer cliCommand for direct execution)",
      "runnable": "boolean? (false means the action is a template and needs additional user input before execution)"
    },
    "rawUnsignedTransaction": {
      "to": "0x-prefixed-address",
      "data": "0x-prefixed-hex-calldata",
      "value": "decimal-string-wei",
      "valueHex": "0x-prefixed-hex-quantity-wei",
      "chainId": "number",
      "description": "string"
    },
    "unsignedTransaction": {
      "chainId": "number",
      "from": "0x-prefixed-address|null",
      "to": "0x-prefixed-address",
      "value": "decimal-string-wei",
      "data": "0x-prefixed-hex-calldata",
      "description": "string"
    },
    "flowWarning": {
      "code": "\"timing_delay_disabled\"|\"amount_pattern_linkability\"",
      "category": "\"privacy\"",
      "message": "string"
    },
    "previewWarning": {
      "code": "\"PREVIEW_VALIDATION_APPROXIMATE\"|\"UNSIGNED_VALIDATION_APPROXIMATE\"",
      "category": "\"preview\"",
      "message": "string"
    },
    "privacyCostManifest": {
      "action": "string",
      "framing": "\"public_direct_withdrawal\"|\"public_self_custody_recovery\"",
      "poolAccountId": "string|null",
      "amount": "decimal-string-wei",
      "asset": "string",
      "chain": "string",
      "recipient": "0x-prefixed-address? (withdraw --direct)",
      "destinationAddress": "0x-prefixed-address|null? (ragequit / flow ragequit)",
      "privacyCost": "string",
      "privacyPreserved": false,
      "recommendation": "string"
    },
    "flowLastError": {
      "step": "string",
      "errorCode": "string",
      "errorMessage": "string",
      "retryable": "boolean",
      "at": "iso8601-string"
    }
  },
  "commands": {
    "init": {
      "successFields": {
        "setupMode": "\"create\"|\"restore\"|\"signer_only\"|\"replace\"",
        "readiness": "\"ready\"|\"read_only\"|\"discovery_required\"",
        "defaultChain": "string",
        "signerKeySet": "boolean",
        "backupFilePath": "string? (present when the generated recovery phrase was written to a backup file)",
        "recoveryPhraseRedacted": "boolean? (true when a new recovery phrase was generated but not printed)",
        "recoveryPhrase": "string? (present only when newly generated and --show-recovery-phrase is provided)",
        "restoreDiscovery": "{ status: \"deposits_found\"|\"no_deposits\"|\"legacy_website_action_required\"|\"degraded\", chainsChecked: string[], foundAccountChains?: string[] }? (present for existing-account load flows)",
        "warning": "string? (security guidance for agents)",
        "nextActions": "NextAction[]? (present when a canonical CLI follow-up is available)"
      }
    },
    "upgrade": {
      "successFields": {
        "mode": "\"upgrade\"",
        "status": "\"up_to_date\"|\"ready\"|\"manual\"|\"cancelled\"|\"upgraded\"",
        "currentVersion": "string",
        "latestVersion": "string",
        "updateAvailable": "boolean",
        "performed": "boolean",
        "command": "string|null",
        "installContext": "{ kind: \"global_npm\"|\"bun_global\"|\"source_checkout\"|\"local_project\"|\"npx\"|\"ci\"|\"unknown\", supportedAutoRun: boolean, reason: string }",
        "installedVersion": "string|null",
        "nextActions": "NextAction[]? (suggests upgrade command when status is ready)"
      }
    },
    "flow": {
      "successFields": {
        "mode": "\"flow\"",
        "action": "\"start\"|\"watch\"|\"status\"|\"ragequit\"",
        "workflowId": "uuid-string",
        "phase": "\"awaiting_funding\"|\"depositing_publicly\"|\"awaiting_asp\"|\"approved_waiting_privacy_delay\"|\"approved_ready_to_withdraw\"|\"withdrawing\"|\"completed\"|\"completed_public_recovery\"|\"paused_declined\"|\"paused_poa_required\"|\"stopped_external\"",
        "walletMode": "\"configured\"|\"new_wallet\"",
        "walletAddress": "0x-prefixed-address|null",
        "requiredNativeFunding": "decimal-string-wei|null",
        "requiredTokenFunding": "decimal-string-wei|null",
        "backupConfirmed": "boolean|undefined (new-wallet flows only)",
        "chain": "string",
        "asset": "string",
        "depositAmount": "decimal-string-wei",
        "recipient": "0x-prefixed-address",
        "poolAccountId": "string (PA-#)|null",
        "poolAccountNumber": "number|null",
        "depositTxHash": "0x-prefixed-hash|null",
        "depositBlockNumber": "decimal-string|null",
        "depositExplorerUrl": "string|null",
        "committedValue": "decimal-string-wei|null",
        "aspStatus": "\"pending\"|\"approved\"|\"poa_required\"|\"declined\"|\"unknown\"|undefined",
        "privacyDelayProfile": "\"off\"|\"balanced\"|\"aggressive\"",
        "privacyDelayConfigured": "boolean (true when the workflow explicitly saved a delay policy; false for legacy snapshots normalized to off)",
        "privacyDelayUntil": "iso8601-string|null",
        "warnings": "FlowWarning[]? (see shared.flowWarning)",
        "withdrawTxHash": "0x-prefixed-hash|null",
        "withdrawBlockNumber": "decimal-string|null",
        "withdrawExplorerUrl": "string|null",
        "ragequitTxHash": "0x-prefixed-hash|null",
        "ragequitBlockNumber": "decimal-string|null",
        "ragequitExplorerUrl": "string|null",
        "privacyCostManifest": "PrivacyCostManifest? (present for action=\"ragequit\")",
        "lastError": "FlowLastError|undefined (see shared.flowLastError)",
        "nextActions": "NextAction[]? (present when a canonical saved-workflow follow-up is available)"
      }
    },
    "status": {
      "successFields": {
        "configExists": "boolean",
        "configDir": "string|null",
        "defaultChain": "string|null",
        "selectedChain": "string|null",
        "rpcUrl": "string|null",
        "rpcIsCustom": "boolean",
        "recoveryPhraseSet": "boolean",
        "signerKeySet": "boolean",
        "signerKeyValid": "boolean",
        "signerAddress": "0x-prefixed-address|null",
        "signerBalance": "decimal-string-wei|undefined (present when rpc check succeeds and signer balance lookup succeeds)",
        "signerBalanceDecimals": "number|undefined (present with signerBalance)",
        "signerBalanceSymbol": "string|undefined (present with signerBalance)",
        "entrypoint": "0x-prefixed-address|null",
        "aspHost": "string|null",
        "accountFiles": "[{ chain: string, chainId: number }]",
        "aspLive": "boolean|undefined (present when health checks run)",
        "rpcLive": "boolean|undefined (present when health checks run)",
        "rpcBlockNumber": "string|undefined (present when rpc check succeeds)",
        "readyForDeposit": "boolean (configuration capability flag: configExists && recoveryPhraseSet && signerKeyValid)",
        "readyForWithdraw": "boolean (configuration capability flag: configExists && recoveryPhraseSet && signerKeyValid)",
        "readyForUnsigned": "boolean (configuration capability flag: configExists && recoveryPhraseSet)",
        "nextActions": "NextAction[]? (present when a canonical CLI follow-up is available)",
        "recommendedMode": "\"setup-required\"|\"read-only\"|\"unsigned-only\"|\"ready\"",
        "blockingIssues": "StatusIssue[]? ({ code, message, affects: (\"deposit\"|\"withdraw\"|\"unsigned\"|\"discovery\")[] })",
        "warnings": "StatusIssue[]? ({ code, message, affects: (\"deposit\"|\"withdraw\"|\"unsigned\"|\"discovery\")[] })"
      }
    },
    "pools": {
      "successFields": {
        "chain": "string (single-chain mode)",
        "allChains": "boolean? (true when no --chain specified)",
        "search": "string|null",
        "sort": "string",
        "chains": "ChainSummary[]? (multi-chain mode: { chain, pools, error })",
        "pools": "Pool[]",
        "warnings": "PoolWarning[]? (multi-chain mode)",
        "nextActions": "NextAction[]? (suggests deposit as a template action)"
      },
      "poolFields": {
        "asset": "string",
        "tokenAddress": "0x-prefixed-address",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string",
