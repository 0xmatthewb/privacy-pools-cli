{
  "name": "privacy-pools-cli-json-contract",
  "version": "1.5.0",
  "schemaVersion": "1.5.0",
  "description": "Stable machine-readable output contract for privacy-pools CLI.",
  "envelope": {
    "successBase": {
      "schemaVersion": "semver-string",
      "success": true
    },
    "errorBase": {
      "schemaVersion": "semver-string",
      "success": false,
      "errorCode": "string",
      "errorMessage": "string",
      "error": {
        "code": "string",
        "category": "INPUT|RPC|ASP|RELAYER|PROOF|CONTRACT|UNKNOWN",
        "message": "string",
        "hint": "string?",
        "retryable": "boolean?"
      }
    }
  },
  "exitCodes": {
    "0": "SUCCESS",
    "1": "UNKNOWN_ERROR",
    "2": "INPUT_ERROR",
    "3": "RPC_ERROR",
    "4": "ASP_ERROR",
    "5": "RELAYER_ERROR",
    "6": "PROOF_ERROR",
    "7": "CONTRACT_ERROR"
  },
  "shared": {
    "nextAction": {
      "command": "string (CLI command name)",
      "reason": "string (why the follow-up is relevant)",
      "when": "string (machine-readable timing label)",
      "args": "string[]? (positional arguments to pass)",
      "options": "Record<string, string|number|boolean|null>? (named options without leading dashes)",
      "runnable": "boolean? (false means the action is a template and needs additional user input before execution)"
    },
    "rawUnsignedTransaction": {
      "to": "0x-prefixed-address",
      "data": "0x-prefixed-hex-calldata",
      "value": "decimal-string-wei",
      "valueHex": "0x-prefixed-hex-quantity-wei",
      "chainId": "number",
      "description": "string"
    },
    "unsignedTransaction": {
      "chainId": "number",
      "from": "0x-prefixed-address|null",
      "to": "0x-prefixed-address",
      "value": "decimal-string-wei",
      "data": "0x-prefixed-hex-calldata",
      "description": "string"
    }
  },
  "commands": {
    "init": {
      "successFields": {
        "defaultChain": "string",
        "signerKeySet": "boolean",
        "recoveryPhraseRedacted": "boolean? (true when a new recovery phrase was generated but not printed)",
        "recoveryPhrase": "string? (present only when newly generated and --show-mnemonic is provided)",
        "warning": "string? (security guidance for agents)",
        "nextActions": "NextAction[]? (present when a canonical CLI follow-up is available)"
      }
    },
    "status": {
      "successFields": {
        "configExists": "boolean",
        "configDir": "string|null",
        "defaultChain": "string|null",
        "selectedChain": "string|null",
        "rpcUrl": "string|null",
        "rpcIsCustom": "boolean",
        "recoveryPhraseSet": "boolean",
        "signerKeySet": "boolean",
        "signerKeyValid": "boolean",
        "signerAddress": "0x-prefixed-address|null",
        "entrypoint": "0x-prefixed-address|null",
        "aspHost": "string|null",
        "accountFiles": "[{ chain: string, chainId: number }]",
        "aspLive": "boolean|undefined (present when health checks run)",
        "rpcLive": "boolean|undefined (present when health checks run)",
        "rpcBlockNumber": "string|undefined (present when rpc check succeeds)",
        "readyForDeposit": "boolean (configuration capability flag: configExists && recoveryPhraseSet && signerKeyValid)",
        "readyForWithdraw": "boolean (configuration capability flag: configExists && recoveryPhraseSet && signerKeyValid)",
        "readyForUnsigned": "boolean (configuration capability flag: configExists && recoveryPhraseSet)",
        "nextActions": "NextAction[]? (present when a canonical CLI follow-up is available)"
      }
    },
    "pools": {
      "successFields": {
        "chain": "string (single-chain mode)",
        "allChains": "boolean? (true when no --chain specified)",
        "search": "string|null",
        "sort": "string",
        "chains": "ChainSummary[]? (multi-chain mode: { chain, pools, error })",
        "pools": "Pool[]",
        "warnings": "PoolWarning[]? (multi-chain mode)"
      },
      "poolFields": {
        "asset": "string",
        "tokenAddress": "0x-prefixed-address",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string",
        "decimals": "number",
        "minimumDeposit": "decimal-string-wei",
        "vettingFeeBPS": "decimal-string",
        "maxRelayFeeBPS": "decimal-string",
        "totalInPoolValue": "decimal-string-wei|null",
        "totalInPoolValueUsd": "string|null",
        "totalDepositsValue": "decimal-string-wei|null",
        "totalDepositsValueUsd": "string|null",
        "acceptedDepositsValue": "decimal-string-wei|null",
        "acceptedDepositsValueUsd": "string|null",
        "pendingDepositsValue": "decimal-string-wei|null",
        "pendingDepositsValueUsd": "string|null",
        "totalDepositsCount": "number|null",
        "acceptedDepositsCount": "number|null",
        "pendingDepositsCount": "number|null",
        "growth24h": "number|null",
        "pendingGrowth24h": "number|null",
        "chain": "string? (present in multi-chain mode)"
      }
    },
    "deposit": {
      "successFields": {
        "operation": "\"deposit\"",
        "txHash": "0x-prefixed-hash",
        "amount": "decimal-string-wei",
        "committedValue": "decimal-string-wei|null",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "label": "decimal-string|null",
        "blockNumber": "decimal-string",
        "explorerUrl": "string|null",
        "nextActions": "NextAction[]? (poll accounts --chain <chain> --pending-only while the Pool Account remains pending; then confirm whether it was approved, declined, or poi_required before choosing withdraw or ragequit)"
      },
      "variants": {
        "dryRun": {
          "dryRun": true,
          "operation": "\"deposit\"",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "precommitment": "decimal-string",
          "balanceSufficient": "boolean|\"unknown\""
        },
        "unsigned": {
          "mode": "unsigned",
          "operation": "deposit",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "precommitment": "decimal-string",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedTx": {
          "--unsigned tx": "RawUnsignedTransaction[]"
        }
      }
    },
    "withdraw": {
      "successFields": {
        "operation": "\"withdraw\"",
        "mode": "\"direct\"|\"relayed\"",
        "txHash": "0x-prefixed-hash",
        "blockNumber": "decimal-string",
        "amount": "decimal-string-wei",
        "recipient": "0x-prefixed-address",
        "explorerUrl": "string|null",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "feeBPS": "null (direct mode) | string (relayed mode)",
        "extraGas": "boolean? (relayed mode only, ERC20 withdrawals)",
        "remainingBalance": "decimal-string-wei",
        "anonymitySet": "{ eligible: number, total: number, percentage: number }? (when available from the ASP)",
        "nextActions": "NextAction[]? (suggests accounts to verify updated balance)"
      },
      "variants": {
        "dryRun": {
          "operation": "\"withdraw\"",
          "mode": "\"direct\"|\"relayed\"",
          "dryRun": true,
          "amount": "decimal-string-wei",
          "asset": "string",
          "chain": "string",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "proofPublicSignals": "number",
          "feeBPS": "string? (relayed only)",
          "quoteExpiresAt": "iso8601-string? (relayed only)",
          "anonymitySet": "{ eligible: number, total: number, percentage: number }? (when available from the ASP)"
        },
        "unsignedDirect": {
          "mode": "unsigned",
          "operation": "withdraw",
          "withdrawMode": "direct",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedRelayed": {
          "mode": "unsigned",
          "operation": "withdraw",
          "withdrawMode": "relayed",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "feeBPS": "string",
          "quoteExpiresAt": "iso8601-string",
          "transactions": "UnsignedTransaction[]",
          "relayerRequest": "object"
        },
        "unsignedTx": {
          "--unsigned tx": "RawUnsignedTransaction[]"
        }
      },
      "subcommands": {
        "quote": {
          "mode": "relayed-quote",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "recipient": "0x-prefixed-address|null",
          "minWithdrawAmount": "decimal-string-wei",
          "minWithdrawAmountFormatted": "string (human-readable e.g. 0.01 ETH)",
          "quoteFeeBPS": "string",
          "feeAmount": "decimal-string-wei",
          "netAmount": "decimal-string-wei",
          "feeCommitmentPresent": "boolean",
          "quoteExpiresAt": "iso8601-string|null",
          "extraGas": "boolean? (ERC20 withdrawals only)",
          "nextActions": "NextAction[]? (structured follow-up commands for agents; check runnable for template actions)"
        }
      }
    },
    "ragequit": {
      "aliases": [
        "exit"
      ],
      "successFields": {
        "operation": "\"ragequit\"",
        "txHash": "0x-prefixed-hash",
        "amount": "decimal-string-wei",
        "asset": "string",
        "chain": "string",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "poolAddress": "0x-prefixed-address",
        "scope": "decimal-string",
        "blockNumber": "decimal-string",
        "explorerUrl": "string|null",
        "nextActions": "NextAction[]? (suggests accounts to verify status after ragequit)"
      },
      "variants": {
        "dryRun": {
          "dryRun": true,
          "operation": "\"ragequit\"",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "proofPublicSignals": "number"
        },
        "unsigned": {
          "mode": "unsigned",
          "operation": "ragequit",
          "chain": "string",
          "asset": "string",
          "amount": "decimal-string-wei",
          "poolAccountNumber": "number",
          "poolAccountId": "string (PA-#)",
          "selectedCommitmentLabel": "decimal-string",
          "selectedCommitmentValue": "decimal-string-wei",
          "transactions": "UnsignedTransaction[]"
        },
        "unsignedTx": {
          "--unsigned tx": "RawUnsignedTransaction[]"
        }
      }
    },
    "accounts": {
      "successFields": {
        "chain": "string (single-chain name, \"all-mainnets\", or \"all-chains\")",
        "allChains": "boolean? (true when --all-chains is used)",
        "chains": "string[]? (queried chains in multi-chain mode)",
        "warnings": "AccountWarning[]? ({ chain, category, message } for per-chain partial failures)",
        "accounts": "Account[]",
        "balances": "Balance[]",
        "pendingCount": "number",
        "nextActions": "NextAction[]? (poll-oriented only; emitted when pending approvals exist)"
      },
      "summaryVariant": {
        "chain": "string (single-chain name, \"all-mainnets\", or \"all-chains\")",
        "allChains": "boolean? (true when --all-chains is used)",
        "chains": "string[]? (queried chains in multi-chain mode)",
        "warnings": "AccountWarning[]? ({ chain, category, message } for per-chain partial failures)",
        "pendingCount": "number",
        "approvedCount": "number",
        "poiRequiredCount": "number",
        "declinedCount": "number",
        "unknownCount": "number",
        "spentCount": "number",
        "exitedCount": "number",
        "balances": "Balance[]",
        "nextActions": "NextAction[]? (poll-oriented only; emitted when pending approvals exist)"
      },
      "pendingOnlyVariant": {
        "chain": "string",
        "accounts": "Account[] (filtered to aspStatus = \"pending\")",
        "pendingCount": "number",
        "nextActions": "NextAction[]? (poll-oriented only; no withdraw suggestions)"
      },
      "accountFields": {
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "status": "\"approved\"|\"pending\"|\"poi_required\"|\"declined\"|\"unknown\"|\"spent\"|\"exited\"",
        "aspStatus": "\"pending\"|\"approved\"|\"poi_required\"|\"declined\"|\"unknown\"",
        "asset": "string",
        "scope": "decimal-string",
        "value": "decimal-string-wei",
        "hash": "decimal-string",
        "label": "decimal-string",
        "blockNumber": "decimal-string",
        "txHash": "0x-prefixed-hash",
        "explorerUrl": "string|null",
        "chain": "string? (present in multi-chain mode)",
        "chainId": "number? (present in multi-chain mode)"
      },
      "balanceFields": {
        "asset": "string",
        "balance": "decimal-string-wei (total across Pool Accounts with remaining balance)",
        "usdValue": "string|null (formatted USD e.g. $1,000.00)",
        "poolAccounts": "number (account count included in the balance total)",
        "chain": "string? (present in multi-chain mode)",
        "chainId": "number? (present in multi-chain mode)"
      }
    },
    "history": {
      "successFields": {
        "chain": "string",
        "events": "HistoryEvent[]"
      },
      "eventFields": {
        "type": "\"deposit\"|\"withdrawal\"|\"ragequit\"",
        "asset": "string",
        "poolAddress": "0x-prefixed-address",
        "poolAccountNumber": "number",
        "poolAccountId": "string (PA-#)",
        "value": "decimal-string-wei",
        "blockNumber": "decimal-string",
        "txHash": "0x-prefixed-hash",
        "explorerUrl": "string|null"
      }
    },
    "activity": {
      "successFields": {
        "mode": "\"pool-activity\"|\"global-activity\"",
        "chain": "string (\"all-mainnets\" for cross-chain global activity, selected chain name otherwise)",
        "chains": "string[]? (global-activity with multiple chains)",
        "page": "number",
        "perPage": "number",
        "total": "number|null",
        "totalPages": "number|null",
        "chainFiltered": "boolean? (true when chain filtering happens client-side)",
        "note": "string? (explains pagination limitations when chainFiltered is true)",
        "events": "ActivityEvent[]"
      },
      "poolActivityExtraFields": {
        "asset": "string",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string"
      },
      "eventFields": {
        "type": "string",
        "txHash": "0x-prefixed-hash|null",
        "explorerUrl": "string|null",
        "reviewStatus": "string|null",
        "amountRaw": "decimal-string-wei|null",
        "amountFormatted": "string|null",
        "poolSymbol": "string|null",
        "poolAddress": "0x-prefixed-address|null",
        "chainId": "number|null",
        "timestamp": "iso8601-string|null"
      }
    },
    "stats": {
      "globalStats": {
        "mode": "\"global-stats\"",
        "chain": "string",
        "chains": "string[]? (multi-chain mode)",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null",
        "perChain": "ChainStatsEntry[]? (multi-chain mode)"
      },
      "poolStats": {
        "mode": "\"pool-stats\"",
        "chain": "string",
        "asset": "string",
        "pool": "0x-prefixed-address",
        "scope": "decimal-string",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null"
      },
      "timeBasedStatisticsFields": {
        "tvlUsd": "string|null",
        "avgDepositSizeUsd": "string|null",
        "totalDepositsCount": "number|null",
        "totalDepositsValue": "decimal-string-wei|null",
        "totalDepositsValueUsd": "string|null",
        "totalWithdrawalsCount": "number|null",
        "totalWithdrawalsValue": "decimal-string-wei|null",
        "totalWithdrawalsValueUsd": "string|null"
      },
      "chainStatsEntryFields": {
        "chain": "string",
        "cacheTimestamp": "iso8601-string|null",
        "allTime": "TimeBasedStatistics|null",
        "last24h": "TimeBasedStatistics|null"
      }
    },
    "capabilities": {
      "successFields": {
        "commands": "Command[]",
        "commandDetails": "Record<string, DetailedCommandDescriptor>",
        "globalFlags": "Flag[]",
        "agentWorkflow": "string[]",
        "jsonOutputContract": "string (descriptive contract summary)",
        "agentNotes": "Record<string, string>",
        "schemas": "object (includes nextActions metadata)",
        "supportedChains": "Chain[]",
        "safeReadOnlyCommands": "string[]"
      }
    },
    "describe": {
      "successFields": {
        "command": "string (canonical command path)",
        "description": "string",
        "aliases": "string[]",
        "usage": "string",
        "flags": "string[]",
        "globalFlags": "string[]",
        "requiresInit": "boolean",
        "expectedLatencyClass": "\"fast\"|\"medium\"|\"slow\"",
        "safeReadOnly": "boolean",
        "prerequisites": "string[]",
        "examples": "string[]",
        "jsonFields": "string|null",
        "jsonVariants": "string[]",
        "safetyNotes": "string[]",
        "supportsUnsigned": "boolean",
        "supportsDryRun": "boolean",
        "agentWorkflowNotes": "string[]"
      }
    },
    "sync": {
      "successFields": {
        "chain": "string",
        "syncedPools": "number",
        "syncedSymbols": "string[]? (present on successful sync)",
        "availablePoolAccounts": "number",
        "previousAvailablePoolAccounts": "number? (count before sync)"
      }
    },
    "guide": {
      "note": "Outputs formatted help text to stderr in interactive mode. In JSON mode, returns the guide as a string.",
      "successFields": {
        "mode": "\"help\"",
        "help": "string (formatted guide text)"
      }
    },
    "meta": {
      "helpEnvelope": {
        "mode": "help",
        "help": "string"
      },
      "versionEnvelope": {
        "mode": "version",
        "version": "semver-string"
      }
    }
  },
  "unsignedCalldataABIs": {
    "depositNative": "function deposit(uint256 _precommitment) payable",
    "depositErc20": "function deposit(address _asset, uint256 _value, uint256 _precommitment)",
    "approveErc20": "function approve(address spender, uint256 amount)",
    "withdrawDirect": "function withdraw((address processooor, bytes data) _withdrawal, (uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[8] pubSignals) _proof)",
    "withdrawRelayed": "function relay((address processooor, bytes data) _withdrawal, (uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[8] pubSignals) _proof, uint256 _scope)",
    "ragequit": "function ragequit((uint256[2] pA, uint256[2][2] pB, uint256[2] pC, uint256[4] pubSignals) _proof)"
  }
}
