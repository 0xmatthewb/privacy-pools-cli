{
  "name": "privacy-pools-cli",
  "version": "2.0.0",
  "description": "CLI for interacting with Privacy Pools v1",
  "type": "module",
  "bin": {
    "privacy-pools": "./dist/index.js"
  },
  "files": [
    "assets",
    "dist",
    "scripts/start-built-cli.mjs",
    "AGENTS.md",
    "CHANGELOG.md",
    "docs/contracts/README.md",
    "docs/contracts/cli-json-contract.current.json",
    "docs/contracts/cli-json-contract.v2.0.0.json",
    "docs/errors.md",
    "docs/man/privacy-pools.1",
    "docs/reference.md",
    "docs/runtime-upgrades.md",
    "schemas",
    "skills"
  ],
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "version": "node scripts/sync-version.mjs",
    "build": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "native:build": "cargo build --manifest-path native/shell/Cargo.toml",
    "native:build:release": "cargo build --manifest-path native/shell/Cargo.toml --release",
    "native:package": "node scripts/prepare-native-package.mjs",
    "anvil:fixture:refresh": "node scripts/refresh-anvil-contract-fixture.mjs",
    "prepare": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "cli": "node --import ./src/runtime/color-env-bootstrap.ts --import tsx src/index.ts",
    "dev": "node --import ./src/runtime/color-env-bootstrap.ts --import tsx src/index.ts",
    "start": "node scripts/start-built-cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-test-suite.mjs",
    "test:offline": "node scripts/run-test-suite.mjs --exclude-tag online && npm run build && node scripts/run-conformance-suite.mjs core --exclude-tag online",
    "test:affected": "node scripts/run-test-affected.mjs",
    "test:parallel": "PP_TEST_MAIN_RESPECT_FIXTURE_CLASS=0 node scripts/run-test-suite.mjs",
    "test:install": "node scripts/run-test-profile.mjs install",
    "test:native:fmt": "cargo fmt --manifest-path native/shell/Cargo.toml --check",
    "test:native:lint": "cargo clippy --manifest-path native/shell/Cargo.toml --tests -- -D warnings",
    "test:native": "cargo test --manifest-path native/shell/Cargo.toml",
    "test:ci": "node scripts/run-test-profile.mjs ci",
    "test:ci:parallel": "PP_TEST_MAIN_RESPECT_FIXTURE_CLASS=0 node scripts/run-test-profile.mjs ci",
    "test:release": "node scripts/run-test-profile.mjs release",
    "test:all": "node scripts/run-test-profile.mjs all",
    "test:timings:refresh": "node scripts/refresh-test-runtime-metadata.mjs",
    "test:shards:refresh": "node scripts/ci/refresh-test-shard-weights.mjs",
    "test:conformance": "node scripts/run-test-profile.mjs conformance",
    "test:conformance:all": "node scripts/run-test-profile.mjs conformance-all",
    "test:conformance:frontend": "npm run build && node scripts/run-conformance-suite.mjs frontend",
    "test:scripts": "node scripts/check-node-scripts.mjs",
    "test:glossary": "node scripts/check-glossary.mjs",
    "test:runtime:boundary": "node scripts/run-test-suite.mjs ./test/unit/launcher-routing.unit.test.ts ./test/unit/launcher-runtime.unit.test.ts ./test/unit/native-runtime-advisory.unit.test.ts ./test/unit/worker-request.unit.test.ts ./test/unit/bootstrap-runtime.unit.test.ts ./test/unit/runtime-current.unit.test.ts ./test/unit/root-argv.unit.test.ts ./test/integration/cli-bun-runtime.integration.test.ts ./test/conformance/native-manifest.conformance.test.ts ./test/conformance/command-discovery-static.conformance.test.ts --timeout 240000",
    "test:fuzz": "node scripts/run-bun-tests.mjs ./test/fuzz --timeout 120000 --process-timeout-ms 600000",
    "test:stress": "node scripts/run-stress.mjs",
    "test:coverage": "node scripts/check-coverage.mjs",
    "test:coverage:native": "node scripts/check-native-coverage.mjs",
    "test:packed-smoke": "node scripts/run-bun-tests.mjs ./test/integration/cli-packaged-smoke.integration.test.ts --timeout 180000 --process-timeout-ms 600000",
    "test:smoke": "npm run test:packed-smoke",
    "test:smoke:native": "npm run test:smoke:native:package",
    "test:smoke:native:shell": "node scripts/run-bun-tests.mjs ./test/integration/cli-native-machine-contract.integration.test.ts ./test/integration/cli-native-routing-smoke.integration.test.ts ./test/integration/cli-native-human-output.integration.test.ts --timeout 300000 --process-timeout-ms 900000",
    "test:smoke:native:package": "node scripts/run-bun-tests.mjs ./test/integration/cli-native-package-smoke.integration.test.ts --timeout 240000 --process-timeout-ms 900000",
    "test:evals": "node scripts/run-bun-tests.mjs ./test/evals --timeout 120000 --process-timeout-ms 600000",
    "test:flake": "node scripts/run-flake-suite.mjs",
    "test:flake:anvil": "node scripts/run-anvil-flake-suite.mjs",
    "test:e2e:anvil": "node scripts/run-anvil-tests.mjs",
    "test:e2e:anvil:smoke": "node scripts/run-anvil-smoke.mjs",
    "discovery:generate": "npm run build && node scripts/generate-command-discovery-static.mjs",
    "discovery:check": "npm run build && node scripts/generate-command-discovery-static.mjs --check",
    "schemas:generate": "npm run build && node scripts/generate-envelope-schemas.mjs --write",
    "schemas:check": "npm run build && node scripts/generate-envelope-schemas.mjs --check",
    "docs:generate": "npm run build && node scripts/generate-reference.mjs --write && node scripts/generate-envelope-schemas.mjs --write && node scripts/generate-json-contract.mjs --write && node scripts/generate-error-docs.mjs --write && node scripts/generate-flow-phase-diagram.mjs --write && node scripts/generate-recovery-table.mjs --write",
    "docs:preview": "npm run build && node scripts/generate-reference.mjs",
    "docs:check": "npm run build && node scripts/generate-reference.mjs --check && node scripts/generate-envelope-schemas.mjs --check && node scripts/generate-json-contract.mjs --check && node scripts/generate-error-docs.mjs --check && node scripts/generate-flow-phase-diagram.mjs --check && node scripts/generate-recovery-table.mjs --check && node scripts/check-glossary.mjs",
    "test:preview:cli": "node --import tsx scripts/preview-cli-visuals.mjs",
    "test:preview:cli:tty": "node --import tsx scripts/preview-cli-visuals-tty.mjs",
    "test:preview:cli:smoke": "node --import tsx scripts/preview-cli-audit.mjs --smoke",
    "test:preview:cli:audit": "node --import tsx scripts/preview-cli-audit.mjs",
    "test:preview:cli:report": "node --import tsx scripts/preview-cli-audit.mjs --report-json",
    "test:artifacts:root": "node scripts/verify-root-only-host-artifact.mjs",
    "test:artifacts:host": "node scripts/verify-current-host-release-artifacts.mjs",
    "bench:gate": "node scripts/bench-cli.mjs --base self --runtime native --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json",
    "bench:gate:readonly": "node scripts/bench-cli.mjs --base self --matrix readonly --runtime launcher-binary-override --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json",
    "bench:gate:release": "node scripts/bench-cli.mjs --base v2.0.0 --runtime native --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json"
  },
  "dependencies": {
    "@0xbow/privacy-pools-core-sdk": "1.2.0",
    "@clack/prompts": "1.2.0",
    "@inquirer/prompts": "8.3.2",
    "@inquirer/select": "5.1.2",
    "@scure/bip39": "2.0.1",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "jmespath": "^0.16.0",
    "ora": "9.3.0",
    "snarkjs": "0.7.6",
    "viem": "2.47.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/jmespath": "^0.15.2",
    "@types/js-yaml": "^4.0.9",
    "@types/semver": "^7.5.8",
    "js-yaml": "^4.1.0",
    "node-pty": "^1.1.0",
    "semver": "^7.6.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "license": "Apache-2.0",
  "author": "matthewb",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-cli"
  },
  "overrides": {
    "jsonpath": "1.3.0",
    "underscore": "1.13.8",
    "brace-expansion": ">=2.0.3"
  }
}
