{
  "name": "privacy-pools-cli",
  "version": "1.7.0",
  "description": "CLI for interacting with Privacy Pools v1",
  "type": "module",
  "bin": {
    "privacy-pools": "./dist/index.js"
  },
  "files": [
    "assets",
    "dist",
    "scripts/start-built-cli.mjs",
    "AGENTS.md",
    "CHANGELOG.md",
    "docs/contracts",
    "docs/reference.md",
    "docs/runtime-upgrades.md",
    "skills"
  ],
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "native:build": "cargo build --manifest-path native/shell/Cargo.toml",
    "native:build:release": "cargo build --manifest-path native/shell/Cargo.toml --release",
    "native:package": "node scripts/prepare-native-package.mjs",
    "anvil:fixture:refresh": "node scripts/refresh-anvil-contract-fixture.mjs",
    "prepare": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "cli": "node --import tsx src/index.ts",
    "dev": "node --import tsx src/index.ts",
    "start": "node scripts/start-built-cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-test-suite.mjs",
    "test:install": "node scripts/run-test-profile.mjs install",
    "test:native:fmt": "cargo fmt --manifest-path native/shell/Cargo.toml --check",
    "test:native:lint": "cargo clippy --manifest-path native/shell/Cargo.toml --tests -- -D warnings",
    "test:native": "cargo test --manifest-path native/shell/Cargo.toml",
    "test:ci": "node scripts/run-test-profile.mjs ci",
    "test:release": "node scripts/run-test-profile.mjs release",
    "test:all": "node scripts/run-test-profile.mjs all",
    "test:conformance": "node scripts/run-test-profile.mjs conformance",
    "test:conformance:all": "node scripts/run-test-profile.mjs conformance-all",
    "test:conformance:frontend": "npm run build && node scripts/run-conformance-suite.mjs frontend",
    "test:scripts": "node scripts/check-node-scripts.mjs",
    "test:runtime:boundary": "node scripts/run-test-suite.mjs ./test/unit/launcher-routing.unit.test.ts ./test/unit/launcher-runtime.unit.test.ts ./test/unit/worker-request.unit.test.ts ./test/unit/bootstrap-runtime.unit.test.ts ./test/unit/runtime-current.unit.test.ts ./test/unit/root-argv.unit.test.ts ./test/integration/cli-bun-runtime.integration.test.ts ./test/conformance/native-manifest.conformance.test.ts ./test/conformance/command-discovery-static.conformance.test.ts --timeout 240000",
    "test:fuzz": "node scripts/run-bun-tests.mjs ./test/fuzz --timeout 120000 --process-timeout-ms 600000",
    "test:stress": "node scripts/run-stress.mjs",
    "test:coverage": "node scripts/check-coverage.mjs",
    "test:coverage:native": "node scripts/check-native-coverage.mjs",
    "test:smoke": "node scripts/run-bun-tests.mjs ./test/integration/cli.packaged-smoke.integration.test.ts --timeout 180000 --process-timeout-ms 600000",
    "test:smoke:native": "npm run test:smoke:native:package",
    "test:smoke:native:shell": "node scripts/run-bun-tests.mjs ./test/integration/cli-native-shell.integration.test.ts --timeout 300000 --process-timeout-ms 900000",
    "test:smoke:native:package": "node scripts/run-bun-tests.mjs ./test/integration/cli-native-package-smoke.integration.test.ts --timeout 240000 --process-timeout-ms 900000",
    "test:evals": "node scripts/run-bun-tests.mjs ./test/evals --timeout 120000 --process-timeout-ms 600000",
    "test:flake": "node scripts/run-flake-suite.mjs",
    "test:flake:anvil": "node scripts/run-anvil-flake-suite.mjs",
    "test:e2e:anvil": "node scripts/run-anvil-tests.mjs",
    "test:e2e:anvil:smoke": "node scripts/run-anvil-smoke.mjs",
    "discovery:generate": "npm run build && node scripts/generate-command-discovery-static.mjs",
    "docs:generate": "npm run build && node scripts/generate-reference.mjs --write",
    "docs:preview": "npm run build && node scripts/generate-reference.mjs",
    "docs:check": "npm run build && node scripts/generate-reference.mjs --check",
    "test:artifacts:root": "node scripts/verify-root-only-host-artifact.mjs",
    "test:artifacts:host": "node scripts/verify-current-host-release-artifacts.mjs",
    "bench:gate": "node scripts/bench-cli.mjs --base self --runtime native --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json",
    "bench:gate:release": "node scripts/bench-cli.mjs --base v1.7.0 --runtime native --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json"
  },
  "dependencies": {
    "@0xbow/privacy-pools-core-sdk": "1.2.0",
    "@inquirer/prompts": "8.3.2",
    "@inquirer/select": "5.1.2",
    "@scure/bip39": "2.0.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "ora": "9.3.0",
    "snarkjs": "0.7.6",
    "viem": "2.47.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  },
  "license": "Apache-2.0",
  "author": "matthewb",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-cli"
  },
  "optionalDependencies": {
    "@0xmatthewb/privacy-pools-cli-native-linux-x64-gnu": "1.7.0",
    "@0xmatthewb/privacy-pools-cli-native-macos-arm64": "1.7.0",
    "@0xmatthewb/privacy-pools-cli-native-macos-x64": "1.7.0",
    "@0xmatthewb/privacy-pools-cli-native-windows-arm64-msvc": "1.7.0",
    "@0xmatthewb/privacy-pools-cli-native-windows-x64-msvc": "1.7.0"
  },
  "overrides": {
    "jsonpath": "1.3.0",
    "underscore": "1.13.8"
  }
}
