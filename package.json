{
  "name": "privacy-pools-cli",
  "version": "0.1.0",
  "description": "CLI for interacting with Privacy Pools v1",
  "type": "module",
  "bin": {
    "privacy-pools": "./dist/index.js",
    "pp": "./dist/index.js"
  },
  "files": [
    "dist",
    "AGENTS.md",
    "skills"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && chmod +x dist/index.js",
    "cli": "bun src/index.ts",
    "dev": "bun src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test ./test/unit ./test/integration ./test/fuzz ./test/services",
    "test:conformance": "bun test ./test/conformance --timeout 120000",
    "test:fuzz": "bun test ./test/fuzz --timeout 120000",
    "test:stress": "PP_STRESS_ENABLED=1 bun test ./test/fuzz/cli.stress-120-rounds.test.ts --timeout 120000",
    "test:coverage": "bun test --coverage",
    "test:release": "PP_EXTERNAL_CONFORMANCE_REQUIRED=1 PP_E2E_REQUIRED=1 PP_E2E_ENABLED=1 bun test --timeout 1800000"
  },
  "dependencies": {
    "@0xbow/privacy-pools-core-sdk": "1.1.0",
    "@inquirer/prompts": "^7.0.0",
    "@scure/bip39": "^1.6.0",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "ora": "^8.2.0",
    "viem": "^2.22.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "license": "Apache-2.0",
  "author": "matthewb",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-cli"
  }
}
