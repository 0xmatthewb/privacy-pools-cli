{
  "name": "privacy-pools-cli",
  "version": "1.7.0",
  "description": "CLI for interacting with Privacy Pools v1",
  "type": "module",
  "bin": {
    "privacy-pools": "./dist/index.js"
  },
  "files": [
    "dist",
    "scripts/start-built-cli.mjs",
    "AGENTS.md",
    "CHANGELOG.md",
    "docs/contracts",
    "docs/reference.md",
    "docs/runtime-upgrades.md",
    "skills"
  ],
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "native:build": "cargo build --manifest-path native/shell/Cargo.toml",
    "native:build:release": "cargo build --manifest-path native/shell/Cargo.toml --release",
    "native:package": "node scripts/prepare-native-package.mjs",
    "circuits:provision": "node scripts/provision-circuits.mjs",
    "prepare": "node scripts/clean-dist.mjs && tsc --project tsconfig.json",
    "cli": "bun src/index.ts",
    "dev": "bun src/index.ts",
    "start": "node scripts/start-built-cli.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-test-suite.mjs",
    "test:ci": "npm test && npm run test:smoke && npm run test:smoke:native && npm run test:coverage && npm run test:e2e:anvil:smoke && node scripts/run-bun-tests.mjs ./test/evals --timeout 120000 && bun run build && node scripts/generate-reference.mjs --check && node scripts/run-conformance-suite.mjs core",
    "test:release": "npm test && npm run test:smoke && npm run test:smoke:native && npm run test:coverage && npm run test:e2e:anvil && node scripts/run-bun-tests.mjs ./test/evals --timeout 120000 && bun run build && node scripts/generate-reference.mjs --check && node scripts/run-conformance-suite.mjs core",
    "test:all": "npm test && npm run test:smoke && npm run test:smoke:native && npm run test:coverage && npm run test:e2e:anvil && node scripts/run-bun-tests.mjs ./test/evals --timeout 120000 && bun run build && node scripts/generate-reference.mjs --check && node scripts/run-conformance-suite.mjs all",
    "test:conformance": "bun run build && node scripts/run-conformance-suite.mjs core",
    "test:conformance:all": "bun run build && node scripts/run-conformance-suite.mjs all",
    "test:conformance:frontend": "bun run build && node scripts/run-conformance-suite.mjs frontend",
    "test:fuzz": "node scripts/run-bun-tests.mjs ./test/fuzz --timeout 120000",
    "test:stress": "node scripts/run-stress.mjs",
    "test:coverage": "node scripts/check-coverage.mjs",
    "test:smoke": "node scripts/run-bun-tests.mjs ./test/integration/cli.packaged-smoke.integration.test.ts --timeout 180000",
    "test:smoke:native": "node scripts/run-bun-tests.mjs ./test/integration/cli-native-package-smoke.integration.test.ts --timeout 240000",
    "test:evals": "node scripts/run-bun-tests.mjs ./test/evals --timeout 120000",
    "test:flake": "node scripts/run-test-suite.mjs --randomize --seed 20260326 && node scripts/run-bun-tests.mjs ./test/acceptance/withdraw-quote.acceptance.test.ts ./test/unit/public-command-handlers.unit.test.ts ./test/unit/status-command-handler.unit.test.ts --rerun-each 3 --timeout 120000",
    "test:e2e:anvil": "node scripts/run-anvil-tests.mjs",
    "test:e2e:anvil:smoke": "node scripts/run-anvil-smoke.mjs",
    "discovery:generate": "bun run build && node scripts/generate-command-discovery-static.mjs",
    "docs:generate": "bun run build && node scripts/generate-reference.mjs --write",
    "docs:preview": "bun run build && node scripts/generate-reference.mjs",
    "docs:check": "bun run build && node scripts/generate-reference.mjs --check",
    "bench:gate": "node scripts/bench-cli.mjs --base self --runtime native --runs 6 --warmup 1 --assert-thresholds scripts/bench-thresholds.json"
  },
  "dependencies": {
    "@0xbow/privacy-pools-core-sdk": "1.2.0",
    "@inquirer/prompts": "8.3.2",
    "@inquirer/select": "5.1.2",
    "@scure/bip39": "2.0.1",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "commander": "14.0.3",
    "dotenv": "17.3.1",
    "ora": "9.3.0",
    "snarkjs": "0.7.6",
    "viem": "2.47.5"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "typescript": "5.9.3"
  },
  "license": "Apache-2.0",
  "author": "matthewb",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xmatthewb/privacy-pools-cli"
  },
  "optionalDependencies": {
    "@0xbow/privacy-pools-cli-native-darwin-arm64": "1.7.0",
    "@0xbow/privacy-pools-cli-native-darwin-x64": "1.7.0",
    "@0xbow/privacy-pools-cli-native-linux-x64-gnu": "1.7.0",
    "@0xbow/privacy-pools-cli-native-win32-arm64-msvc": "1.7.0",
    "@0xbow/privacy-pools-cli-native-win32-x64-msvc": "1.7.0"
  },
  "overrides": {
    "jsonpath": "1.3.0",
    "underscore": "1.13.8"
  }
}
